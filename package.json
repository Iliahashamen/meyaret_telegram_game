{
  "name": "meyaret",
  "version": "1.0.0",
  "description": "MEYARET - Synthwave Asteroids Telegram Mini App",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "setup-db": "node scripts/setup-db.js",
    "story-pdf": "node scripts/generate-story-pdf.js",
    "test": "node -e \"const fs=require('fs');const p=['server/index.js','public/game.js','public/db.js','public/sounds.js'].map(f=>require('path').join(process.cwd(),f));const o=p.filter(f=>fs.existsSync(f)).length;console.log(o===p.length?'OK':('Missing:'+p.filter(f=>!fs.existsSync(f)).join(', ')));process.exit(o===p.length?0:1);\"",
    "test:all": "node scripts/test-all.js"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@supabase/supabase-js": "^2.39.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "grammy": "^1.21.1",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pdfkit": "^0.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
