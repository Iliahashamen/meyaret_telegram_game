# ── MEYARET Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in all values. NEVER commit .env to Git.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram. Do NOT paste real tokens here.
TELEGRAM_BOT_TOKEN=

# The URL Telegram opens when a user taps the Play button.
# Option A — Railway serves frontend + backend (simple):
#   MINI_APP_URL=https://your-app.up.railway.app
# Option B — GitHub Pages for frontend, Railway for API (recommended):
#   MINI_APP_URL=https://your-github-username.github.io/your-repo/
MINI_APP_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# ANON key is served to the browser via /api/config — never stored in client source
SUPABASE_ANON_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# In production (Railway) also set:
# NODE_ENV=production
# WEBHOOK_URL=https://your-app.up.railway.app

# ── Admin ──────────────────────────────────────────────────────────────────────
# Your Telegram user ID — grants access to /tools, EXCLUDED from weekly event
# Find it by sending /ping to the bot and reading the response
ADMIN_TELEGRAM_ID=

# ── Weekly Event (optional) ───────────────────────────────────────────────────
# Top 3 pilots each week get 6,500 $$. Runs Tuesday 10:00 local time.
WEEKLY_EVENT_TZ=Asia/Jerusalem
# Optional: for external cron (cron-job.org). POST /api/cron/weekly-payout with X-Cron-Secret header.
# CRON_SECRET=your-random-secret
