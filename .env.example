# ── MEYARET Environment Variables ──────────────────────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to Git.

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# The URL Telegram opens when a user taps the Play button.
# Option A — Railway serves frontend + backend (simple):
#   MINI_APP_URL=https://your-app.up.railway.app
# Option B — GitHub Pages for frontend, Railway for API (free + fast):
#   MINI_APP_URL=https://iliahashamen.github.io/meyaret_telegram_game/
MINI_APP_URL=https://iliahashamen.github.io/meyaret_telegram_game/

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://fbcjmniqwqiurssdqnka.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt
SUPABASE_ANON_KEY=your_anon_jwt

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# In production (Railway) also set:
# NODE_ENV=production
# WEBHOOK_URL=https://your-app.up.railway.app

# ── Admin ──────────────────────────────────────────────────────────────────────
# Your Telegram user ID — grants access to /tools and /gift
# Find it by sending /ping to the bot after deploy
ADMIN_TELEGRAM_ID=1357754255
