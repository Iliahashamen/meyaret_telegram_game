# ── MEYARET Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# The public HTTPS URL where your Mini App is served.
# In production this is your Railway / Vercel URL.
# For local dev, use ngrok: ngrok http 3000  →  https://xxxx.ngrok.io
MINI_APP_URL=https://your-app.railway.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# In production set NODE_ENV=production and provide your public URL for webhook:
# WEBHOOK_URL=https://your-app.railway.app
# ALLOWED_ORIGIN=https://your-app.railway.app
